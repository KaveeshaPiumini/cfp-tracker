# Thunder Identity Provider (Oracle Cloud VM)
THUNDER_BASE_URL=https://your-thunder-domain.com
THUNDER_CLIENT_ID=your-thunder-client-id
THUNDER_REDIRECT_URI=https://your-vercel-domain.vercel.app/api/auth/callback
NEXT_PUBLIC_THUNDER_BASE_URL=https://your-thunder-domain.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Session (generate with: openssl rand -hex 32)
SESSION_SECRET=your-random-32-byte-hex-string-here-must-be-at-least-32-chars
SESSION_COOKIE_NAME=cfp_session
